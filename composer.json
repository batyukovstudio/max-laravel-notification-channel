{
    "name": "batyukovstudio/max-laravel-notification-channel",
    "description": "MAX Notifications Channel for Laravel",
    "license": "MIT",
    "keywords": [
        "max notification",
        "laravel",
        "max",
        "messenger",
        "notification",
        "max notifications channel"
    ],
    "authors": [
        {
            "name": "ООО «Студия Батюкова»",
            "homepage": "https://www.batyukovstudio.com/",
            "role": "Maintainer"
        }
    ],
    "homepage": "https://github.com/batyukovstudio/max-laravel-notification-channel",
    "support": {
        "issues": "https://github.com/batyukovstudio/max-laravel-notification-channel/issues",
        "source": "https://github.com/batyukovstudio/max-laravel-notification-channel"
    },
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.8",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/notifications": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "mockery/mockery": "^1.4.4",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.2",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "NotificationChannels\\Max\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NotificationChannels\\Max\\Tests\\": "tests"
        }
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "NotificationChannels\\Max\\MaxServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "test": "pest",
        "test-coverage": "pest --coverage"
    }
}
